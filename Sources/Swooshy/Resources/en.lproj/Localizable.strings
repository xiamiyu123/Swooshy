"settings.experimental.section" = "Experimental";
"settings.experimental.browser_tab_close.enabled" = "Enable tab close gesture";
"settings.experimental.browser_tab_close.footer" = "Allows you to map gestures to 'Close Tab'.\n\nPrinciple: Swooshy simulates a middle-click at the pointer location. Before using this feature, make sure the target app supports middle-click to close tabs and that no third-party button remapping conflicts are present.";
"settings.experimental.smart_browser_tab_close.enabled" = "Smart tab close";
"settings.experimental.smart_browser_tab_close.footer" = "When performing a 'Close Window' or 'Quit Application' gesture on a supported browser, or on a supported VS Code-based editor, if the pointer is hovering over a specific tab, Swooshy will close only that tab instead of closing the whole window or quitting the app. If the pointer is not over any tab, the gesture falls back to the normal close or quit behavior. Supported apps include browsers such as Safari, Chrome, Edge, and Firefox, as well as VS Code-based code editors such as Visual Studio Code, Cursor, and Antigravity.\n\nNote: Experimental features are not guaranteed to work and may be unstable.";
"settings.experimental.opt_in_persistence.footer" = "Note: Resetting user configuration keeps your experimental feature opt-in state.";

"guide.page.experimental.title" = "Experimental Features";
"guide.page.experimental.message" = "Swooshy includes a few experimental features you can opt into. These are disabled by default but can be turned on in Advanced Settings.\n\nNote: Experimental features are not guaranteed to work and may be unstable.";
"guide.page.experimental.bullet1" = "Smart tab close: when gesturing to close or quit on a supported browser or on a supported VS Code-based editor, Swooshy detects if the pointer is over a specific tab and closes only that tab via a simulated middle-click.";
"guide.page.experimental.bullet2" = "If the pointer is not over any tab, the gesture falls back to the normal close-window or quit behavior.";
"guide.page.experimental.bullet3" = "Supports major browsers, and also supports VS Code-based editors such as Visual Studio Code, Cursor, Antigravity, and more.";

